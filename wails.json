{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "YSM-Model-Manager",
  "outputfilename": "YSM-Model-Manager",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "http://localhost:5173",

  "build": {
    "dir": "build"
  },
  "bind": [
    "GetMinecraftPath",
    "SelectDirectory",
    "ScanModelEntries",
    "ListVersionInstances",
    "InstallModelTo",
    "InstallModelFile",
    "ListFileNames",
    "OpenFolder",
    "CreateDir",
    "MoveModelFile",
    "GetImportLogs",
    "ClearImportLogs",
    "AddImportLog",
    "GetGlobalCustomDir",
    "InstallModelWithOverlay",
    "SyncCustomToRepo",
    "ScanCustomModels",
    "CheckFileExists",
    "GetInstanceStatus",
    "ToggleModelEnable",
    "IsFileBanned",
    "SetRepoRoot",
    "ImportModelFile",
    "ImportModelFileSkipCheck",
    "SaveWindowPosition",
    "MoveToRecycle",
    "ListRecycleBin",
    "RestoreFromRecycle",
    "DeleteFromRecycle",
    "EmptyRecycleBin",
    "SyncModelToggleStatus",
    "SetLinkMode",
    "GetLinkMode",
    "HasYSMMod",
    "GetWindowPosition",
    "ClearCustomDir",
    "RenameDir",
    "RenameFile",
    "RemoveDir",
    "DeduplicateCustomDir",
    "CountLinkedModels",
    "IsSymlink",
    "RelinkCustomDir",
    "AnalyzeYSMModel",
    "ExtractYsmSummary",
    "ExtractYSMHeader",
    "LoadWorkshopSites",
    "SaveWorkshopSites",
    "LoadWorkshopCreators",
    "SaveWorkshopCreators",
    "ListModelAuthors",
    "ResetWorkshopConfigs",
    "GenerateRepoIndex",
    "DownloadFromGitHub",
    "StartProxy",
    "StopProxy",
    "IsProxyRunning",
    "CurrentVersion",
    "CheckUpdate",
    "DownloadUpdate",
    "ApplyUpdate",
    "ExportWorkshopSitesJSONFile",
    "ImportWorkshopSitesJSONFile",
    "ExportWorkshopCreatorsJSONFile",
    "ImportWorkshopCreatorsJSONFile",
    "BackupWorkshopCreators",
    "MergeWorkshopCreatorsFromJSON",
    "ReplaceWorkshopCreatorsFromJSON"
  ]
}
